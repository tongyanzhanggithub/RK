generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id                   String                @id @default(cuid())
  slug                 String                @unique
  name                 String
  subtitle             String?
  sku                  String                @unique
  category             String
  brand                String?
  shortDescription     String
  description          String?
  status               String                @default("ACTIVE")
  priceRange           String
  priceCents           Int
  currency             String                @default("usd")
  compareAtPriceCents  Int?
  wholesalePriceCents  Int?
  costPriceCents       Int?
  allowCoupons         Boolean               @default(true)
  stock                Int                   @default(0)
  lowStockThreshold    Int                   @default(5)
  weightGrams          Int?
  lengthMm             Int?
  widthMm              Int?
  heightMm             Int?
  wholesaleAvailable   Boolean               @default(false)
  isFeatured           Boolean               @default(false)
  isHotSeller          Boolean               @default(false)
  fitmentType          String                @default("SPECIFIC")
  fitmentNote          String?
  fitmentGuaranteed    Boolean               @default(false)
  tags                 String
  compatibleModels     String
  compatibleEquipment  String
  problemsSolved       String
  kitIncludes          String
  notCompatibleWith    String?
  specifications       String?
  faqs                 String?
  images               String?
  image                String?
  seoTitle             String?
  seoDescription       String?
  seoKeywords          String?
  ogImage              String?
  inventoryAdjustments InventoryAdjustment[]
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
}

model Customer {
  id                    String                 @id @default(cuid())
  email                 String                 @unique
  name                  String
  phone                 String?
  whatsapp              String?
  country               String?
  city                  String?
  address               String?
  postalCode            String?
  status                String                 @default("ACTIVE")
  role                  String                 @default("CUSTOMER")
  tags                  String                 @default("[]")
  internalNote          String?
  vatNumber             String?
  passwordHash          String?
  resetTokenHash        String?
  resetTokenExpiresAt   DateTime?
  wholesaleApprovedAt   DateTime?
  orders                Order[]
  wholesaleApplications WholesaleApplication[]
  addresses             CustomerAddress[]
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
}

model QuoteRequest {
  id            String   @id @default(cuid())
  contactName   String
  company       String?
  country       String
  email         String
  whatsapp      String?
  // JSON: [{ slug, name, sku, quantity }]
  items         String
  itemCount     Int      @default(0)
  totalQuantity Int      @default(0)
  message       String?
  status        String   @default("NEW")
  adminNote     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt

  @@index([status])
  @@index([createdAt])
}

model WholesaleApplication {
  id                       String    @id @default(cuid())
  customerId               String?
  customer                 Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  companyName              String
  contactName              String
  country                  String
  whatsapp                 String
  email                    String
  businessType             String
  productInterest          String
  estimatedMonthlyQuantity Int?
  website                  String?
  businessAddress          String?
  salesChannel             String?
  message                  String?
  status                   String    @default("PENDING")
  adminNote                String?
  reviewedBy               String?
  reviewedAt               DateTime?
  notificationStatus       String    @default("NOT_SENT")
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  @@index([customerId])
  @@index([status])
  @@index([createdAt])
}

model Order {
  id                      String      @id @default(cuid())
  orderNumber             String      @unique
  customerId              String?
  customer                Customer?   @relation(fields: [customerId], references: [id], onDelete: SetNull)
  couponId                String?
  coupon                  Coupon?     @relation(fields: [couponId], references: [id], onDelete: SetNull)
  couponCode              String?
  couponType              String?
  couponValue             Int?
  couponUsageRecorded     Boolean     @default(false)
  inventoryReduced        Boolean     @default(false)
  customerName            String
  customerEmail           String
  customerPhone           String?
  customerWhatsapp        String?
  country                 String
  city                    String?
  shippingAddress         String?
  postalCode              String?
  currency                String      @default("usd")
  subtotalCents           Int
  shippingCents           Int         @default(0)
  taxCents                Int         @default(0)
  discountCents           Int         @default(0)
  refundedCents           Int         @default(0)
  totalCents              Int
  paymentMethod           String      @default("stripe")
  paymentRef              String?
  paymentStatus           String      @default("PENDING")
  paymentFailureMessage   String?
  orderStatus             String      @default("PROCESSING")
  fulfillmentStatus       String      @default("UNFULFILLED")
  stripeCheckoutSessionId String?
  stripePaymentIntentId   String?
  stripeLastEventId       String?
  stripeLastEventType     String?
  stripeLastSyncedAt      DateTime?
  paidAt                  DateTime?
  confirmationEmailSentAt DateTime?
  shippingEmailSentAt     DateTime?
  refundEmailSentAt       DateTime?
  shippingCarrier         String?
  trackingNumber          String?
  trackingUrl             String?
  shippedAt               DateTime?
  disputeStatus           String?
  riskLevel               String?
  riskScore               Int?
  internalNote            String?
  items                   OrderItem[]
  events                  OrderEvent[]
  shipments               Shipment[]
  returnRequests          ReturnRequest[]
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt
}

// Append-only audit trail: status changes, refunds, emails, shipments, disputes.
model OrderEvent {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  type      String
  message   String
  actor     String   @default("system")
  createdAt DateTime @default(now())

  @@index([orderId])
}

// Multi-package fulfilment: an order can ship in several parcels.
model Shipment {
  id             String   @id @default(cuid())
  orderId        String
  order          Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  carrier        String?
  trackingNumber String?
  trackingUrl    String?
  note           String?
  shippedAt      DateTime @default(now())
  createdAt      DateTime @default(now())

  @@index([orderId])
}

// Return / RMA workflow.
model ReturnRequest {
  id          String   @id @default(cuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderNumber String
  status      String   @default("REQUESTED") // REQUESTED | APPROVED | RECEIVED | REFUNDED | REJECTED | CLOSED
  resolution  String   @default("REFUND") // REFUND | REPLACE | REPAIR
  reason      String?
  adminNote   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([orderId])
  @@index([status])
}

model Coupon {
  id                      String    @id @default(cuid())
  code                    String    @unique
  type                    String
  value                   Int
  isActive                Boolean   @default(true)
  minSubtotalCents        Int?
  usageLimit              Int?
  usageCount              Int       @default(0)
  perCustomerLimit        Int?
  startsAt                DateTime?
  endsAt                  DateTime?
  allowWholesaleCustomers Boolean   @default(false)
  orders                  Order[]
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  @@index([code])
  @@index([isActive])
  @@index([startsAt])
  @@index([endsAt])
}

model InventoryAdjustment {
  id            String   @id @default(cuid())
  productId     String
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  type          String
  quantityDelta Int
  stockBefore   Int
  stockAfter    Int
  reason        String?
  reference     String?
  createdBy     String?
  createdAt     DateTime @default(now())
}

model OrderItem {
  id             String   @id @default(cuid())
  orderId        String
  order          Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId      String?
  productName    String
  productSlug    String
  sku            String
  unitPriceCents Int
  quantity       Int
  subtotalCents  Int
  image          String?
  createdAt      DateTime @default(now())
}

model AdminUser {
  id                  String    @id @default(cuid())
  email               String    @unique
  name                String
  passwordHash        String
  role                String    @default("ADMIN")
  resetTokenHash      String?
  resetTokenExpiresAt DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

model Testimonial {
  id          String   @id @default(cuid())
  authorName  String
  company     String?
  country     String
  content     String
  contentZh   String?
  rating      Int      @default(5)
  isPublished Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Problem {
  id                      String   @id @default(cuid())
  slug                    String   @unique
  title                   String
  description             String
  difficulty              String   @default("moderate")
  timeEstimate            String   @default("")
  videoUrl                String?
  // JSON-encoded string arrays / object (SQLite has no native JSON):
  commonCauses            String   @default("[]")
  checkSteps              String   @default("[]")
  toolsNeeded             String   @default("[]")
  recommendedProductSlugs String   @default("[]")
  affectedModels          String   @default("[]")
  decisionTree            String?
  status                  String   @default("PUBLISHED")
  sortOrder               Int      @default(0)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @default(now()) @updatedAt

  @@index([status])
  @@index([sortOrder])
}

model Equipment {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String
  createdAt   DateTime @default(now())
}

model EngineModel {
  id                String   @id @default(cuid())
  slug              String   @unique
  name              String
  description       String
  compatibilityNote String
  createdAt         DateTime @default(now())
}

model Category {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive])
  @@index([sortOrder])
}

model RepairGuide {
  id             String   @id @default(cuid())
  slug           String   @unique
  title          String
  excerpt        String?
  content        String?
  videoUrl       String?
  status         String   @default("DRAFT")
  seoTitle       String?
  seoDescription String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([status])
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model CustomerAddress {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  recipient  String
  phone      String?
  country    String
  city       String?
  line1      String
  postalCode String?
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([customerId])
}
