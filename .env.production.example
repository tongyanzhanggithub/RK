# ============================================================
# 生产环境变量清单（部署到 Vercel 时填入 Vercel 的 Environment Variables）
# 不要把真实值提交到 git！本文件只是模板。
# ============================================================

# --- 数据库（Neon / Supabase / Vercel Postgres 的连接串）---
# 形如：postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# --- 站点地址（绑定域名后改成你的正式域名）---
NEXT_PUBLIC_SITE_URL="https://www.your-domain.com"

# --- 联系方式 ---
NEXT_PUBLIC_WHATSAPP_NUMBER="8613800000000"   # 纯数字，含国家码，不要 + 和空格
NEXT_PUBLIC_CONTACT_EMAIL="sales@your-domain.com"

# --- Stripe（生产密钥，从 Stripe Dashboard 的 Live 模式获取）---
STRIPE_SECRET_KEY="sk_live_xxxxxxxx"
STRIPE_WEBHOOK_SECRET="whsec_xxxxxxxx"        # 在 Stripe 配置 Webhook 后获取

# --- 管理员会话密钥（务必用强随机值，生产环境必填，否则启动报错）---
# 生成方法：node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
ADMIN_SESSION_SECRET="替换成一段长随机字符串"

# --- 图片云存储（Vercel Blob，在 Vercel 项目里创建 Blob Store 后自动注入）---
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxx"

# --- 邮件发送（SMTP，启用订单/批发/密码重置邮件）---
SMTP_HOST="smtp.your-provider.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="you@your-domain.com"
SMTP_PASS="你的SMTP密码"
SMTP_FROM="RepairKit Supply <noreply@your-domain.com>"
ADMIN_NOTIFY_EMAIL="admin@your-domain.com"

# --- 网站访问统计（可选）---
NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"

# --- 后台 IP 白名单（可选，安全加固；多个 IP 用逗号分隔，留空则不限制）---
ADMIN_IP_ALLOWLIST=""
