# ============================================================
# 生产环境变量清单 —— 阿里云 ECS 部署
# 复制到服务器上的 .env.production（或 PM2 env），不要提交真实值到 git！
# ============================================================

# --- 数据库（阿里云 RDS PostgreSQL 连接串）---
# RDS 控制台 → 数据库连接 → 取「内网地址」(同 VPC 的 ECS 走内网，免公网流量费、更快更安全)
# 形如：postgresql://用户:密码@rm-xxxx.pg.rds.aliyuncs.com:5432/rk?schema=public
# 初期省钱也可在 ECS 本机自建 PostgreSQL：postgresql://rk:密码@localhost:5432/rk?schema=public
DATABASE_URL="postgresql://USER:PASSWORD@rm-xxxx.pg.rds.aliyuncs.com:5432/rk?schema=public&sslmode=require"

# --- 站点地址（绑定域名后改成你的正式域名，必须 https）---
NEXT_PUBLIC_SITE_URL="https://www.your-domain.com"

# --- 联系方式 / 公司信息（Stripe、Google、Meta 审核会查）---
NEXT_PUBLIC_WHATSAPP_NUMBER="8613800000000"   # 纯数字含国家码，不要 + 和空格
NEXT_PUBLIC_CONTACT_EMAIL="sales@your-domain.com"
NEXT_PUBLIC_COMPANY_NAME="Your Registered Company Name"
NEXT_PUBLIC_COMPANY_ADDRESS="Full registered business address"
NEXT_PUBLIC_COMPANY_PHONE="+86 ..."
NEXT_PUBLIC_COMPANY_HOURS="Mon-Sat, 09:00-18:00 (GMT+8)"

# --- Stripe（生产密钥，从 Stripe Dashboard 的 Live 模式获取）---
STRIPE_SECRET_KEY="sk_live_xxxxxxxx"
STRIPE_WEBHOOK_SECRET="whsec_xxxxxxxx"        # 在 Stripe 配置 Webhook(指向 https://你的域名/api/stripe/webhook)后获取
STRIPE_AUTOMATIC_TAX="0"                       # 启用 Stripe Tax 后再设为 1（挂牌价含税，结账拆出 VAT）
STRIPE_MULTICURRENCY="0"                        # 设为 1 用本地币种(GBP/EUR/AED/SAR/SGD)真实扣款

# --- PayPal（备用支付通道；上线用 live）---
PAYPAL_CLIENT_ID=""
PAYPAL_SECRET=""
PAYPAL_ENV="live"             # 上线用 live；测试用 sandbox
PAYPAL_WEBHOOK_ID=""          # PayPal 后台创建 Webhook(指向 https://你的域名/api/payments/paypal/webhook)后获得

# --- Airwallex（主卡通道，待接入；配齐后结账页"信用卡"自动改走 Airwallex）---
# AIRWALLEX_CLIENT_ID=""
# AIRWALLEX_API_KEY=""
# AIRWALLEX_ENV="prod"

# --- 会话密钥（务必用强随机值，生产必填）---
# 生成：node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
ADMIN_SESSION_SECRET="替换成一段长随机字符串"
CUSTOMER_SESSION_SECRET="替换成另一段不同的长随机字符串"

# --- 图片存储 ---
# 默认：不配下面任何一项 → 图片存 ECS 本机磁盘 public/uploads/（单机部署够用，记得给磁盘做快照备份）。
# 多机/想走 CDN 时再启用阿里云 OSS（需在 app/api/admin/upload/route.ts 接入 OSS SDK，详见部署文档）。
# OSS_REGION="oss-ap-southeast-1"
# OSS_BUCKET="your-bucket"
# OSS_ACCESS_KEY_ID="xxxx"
# OSS_ACCESS_KEY_SECRET="xxxx"
# OSS_PUBLIC_BASE_URL="https://your-bucket.oss-ap-southeast-1.aliyuncs.com"

# --- 邮件发送（SMTP，启用订单/批发/密码重置邮件）---
SMTP_HOST="smtp.your-provider.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="you@your-domain.com"
SMTP_PASS="你的SMTP密码"
SMTP_FROM="RepairKit Supply <noreply@your-domain.com>"
ADMIN_NOTIFY_EMAIL="admin@your-domain.com"

# --- 弃单挽回 cron 密钥(保护 /api/cron/abandoned-cart;crontab 用它调用)---
# 生成：node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"
CRON_SECRET="替换成一段随机字符串"

# --- Cloudflare Turnstile 验证码(防垃圾询盘/评价;不填则不启用验证码)---
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# --- 网站访问统计（可选）---
NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"

# --- 后台 IP 白名单（可选安全加固；多个 IP 用逗号分隔，留空不限制）---
ADMIN_IP_ALLOWLIST=""
