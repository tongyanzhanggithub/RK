# 本地开发用 PostgreSQL（与 docker-compose.dev.yml 默认一致）。
# 起本地库：docker compose -f docker-compose.dev.yml up -d
DATABASE_URL="postgresql://rk:rk_dev_password@localhost:5432/rk?schema=public"
NEXT_PUBLIC_SITE_URL="http://127.0.0.1:4173"
NEXT_PUBLIC_WHATSAPP_NUMBER="8613800000000"
NEXT_PUBLIC_CONTACT_EMAIL="sales@repairkit-supply.com"
# Real business details shown on Contact / Terms / Privacy pages.
# REQUIRED (real values) for Stripe / Google / Meta review:
NEXT_PUBLIC_COMPANY_NAME="Your Registered Company Name"
NEXT_PUBLIC_COMPANY_ADDRESS="Full registered business address"
NEXT_PUBLIC_COMPANY_PHONE="+86 ..."
NEXT_PUBLIC_COMPANY_HOURS="Mon-Sat, 09:00-18:00 (GMT+8)"
STRIPE_SECRET_KEY="sk_test_replace_with_your_key"
STRIPE_WEBHOOK_SECRET="whsec_replace_with_your_webhook_secret"
# Set to 1 ONLY after enabling Stripe Tax in the dashboard. Then listed prices are
# treated as VAT-inclusive and Stripe breaks out the VAT at checkout (UK 20%, etc.).
STRIPE_AUTOMATIC_TAX="0"
# Set to 1 to charge visitors in their local currency (GBP/EUR/AED/SAR/SGD) using the
# region FX rates. Requires your Stripe account to support those presentment currencies.
# Off → everyone charged in USD (local currency shown only as an estimate).
STRIPE_MULTICURRENCY="0"
ADMIN_SESSION_SECRET="replace_with_a_long_random_admin_session_secret"
# Customer (storefront) login session secret. Falls back to ADMIN_SESSION_SECRET if unset.
CUSTOMER_SESSION_SECRET="replace_with_a_different_long_random_secret"

# Email notifications (optional — leave SMTP_HOST unset to disable)
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="you@example.com"
SMTP_PASS="your_smtp_password"
SMTP_FROM="RepairKit Supply <noreply@repairkit-supply.com>"
ADMIN_NOTIFY_EMAIL="admin@repairkit-supply.com"

# --- PayPal (备用支付；不填则结账页不显示 PayPal 按钮) ---
PAYPAL_CLIENT_ID=""
PAYPAL_SECRET=""
PAYPAL_ENV="sandbox"          # sandbox | live
PAYPAL_WEBHOOK_ID=""          # 在 PayPal 后台创建 Webhook 后获得，用于校验回调签名

# --- Airwallex (主卡通道，待接入；配齐后结账页的"信用卡"按钮自动改走 Airwallex 取代 Stripe) ---
# AIRWALLEX_CLIENT_ID=""
# AIRWALLEX_API_KEY=""
# AIRWALLEX_ENV="demo"        # demo | prod

# --- 弃单挽回 cron 密钥(保护 /api/cron/abandoned-cart;定时任务用它调用) ---
CRON_SECRET=""

# Google Analytics 4 (optional — leave unset to disable)
NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"
